{
	"compilerOptions": {
		"strictNullChecks": false,
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"module": "es6",
		"target": "es2017",
		"allowJs": true,
		"experimentalDecorators": true,
		"moduleResolution": "bundler",
		"types": ["node"],
		"typeRoots": ["node_modules/@types"]
	},
	"include": ["src/**/*", "src/types/*.d.ts"]
}
